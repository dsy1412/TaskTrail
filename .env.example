NEXTAUTH_URL=https://tasktrail-six.vercel.app
NEXTAUTH_SECRET=replace-with-a-random-secret
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret

# Optional, but required for durable cross-device sync on Vercel.
# Vercel KV and Upstash Redis REST variables are both supported.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
